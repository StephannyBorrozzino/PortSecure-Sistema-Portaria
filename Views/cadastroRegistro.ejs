<!DOCTYPE html>
<html lang="pt-br">
  <%- include('partials/head') %>

  <body>
    <%- include('partials/header') %>

    <div class="divisao-tela">
      <%- include('partials/nav') %>

      <div class="conteudo-principal-cadastroDeRegistro">
        <h1>Cadastro de Registro</h1>
        <div class="formulario-cadastro-registro">
          <% if (alerta) { %>
            <div id="modalAlerta" class="modal-backdrop show">
              <div class="modal-card">
                <p><%= alerta %></p>
                <button type="button" id="modalClose">OK</button>
              </div>
            </div>
          <% } %>
          <form action="/cadastroDeRegistro" method="POST">
            <div class="nomeUsuario-fomulario-cadastroRegistro">
              <label for="nome">Nome Completo:</label>
              <input
                type="text"
                id="nome-usuario"
                name="nome"
                value="<%= (dados && dados.nome) || '' %>"
                required
                title="Insira o nome completo do usuário cadastrado no sistema."
              />
            </div>

            <div class="divisao-CPFeHorario">
              <div class="CPFusuario-fomulario-cadastroRegistro">
                <label for="id">CPF:</label>
                <input
                  type="number"
                  id="cpf-usuario"
                  name="cpf"
                  value="<%= (dados && dados.cpf) || '' %>"
                  required
                  title="Insira o CPF do usuário cadastrado no sistema."
                  class="input-number"
                />
              </div>
              <div class="HorarioUsuario-fomulario-cadastroRegistro">
                <label for="horarioExibicao">Horário:</label>
                <input type="text" id="horarioExibicao" readonly />

                <!-- Campo hidden para enviar o timestamp ao servidor -->
                <input type="hidden" id="horario" name="horario" required />
              </div>
            </div>

            <div class="movimento-fomulario-cadastroRegistro">
              <label for="movimentacao">Movimentação:</label>
              <div class="movimentacao-registro">
                <div class="correcao-posicao-entrada">
                  <input
                    type="radio"
                   id="entrada"
                   name="movimentacao"
                    value="entrada"
                    <%= (dados && dados.movimentacao) === 'entrada' ? 'checked' : '' %>
                    required
                 />
                  <label for="entrada">Entrada</label>
                </div>

                <div class="correcao-posicao-saida">
                  <input
                   type="radio"
                   id="saida"
                   name="movimentacao"
                   value="saida"
                   <%= (dados && dados.movimentacao) === 'saida' ? 'checked' : '' %>
                   required
                  />
                  <label for="saida">Saída</label>
                </div>
              </div>
              <button class="botao-limparRadio-cadastroRegistro" type="button" id="limparMovimentacao">
                Limpar seleção
              </button>
            </div>

            <button class="botao-registrar-cadastroRegistro" type="submit">
              Registrar Movimentação
            </button>
          </form>
        </div>
      </div>
    </div>

    <%- include('partials/footer') %>
    <script src="/js/cadastroRegistro_horario.js"></script>
    <script src="/js/cadastroRegistro_modal.js"></script>
  </body>
</html>
