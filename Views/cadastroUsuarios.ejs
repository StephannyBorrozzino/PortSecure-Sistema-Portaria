<!DOCTYPE html>
<html lang="pt-br">
  <%- include('partials/head') %>

  <body>
    <%- include('partials/header') %>

    <div class="divisao-tela">
      <%- include('partials/nav') %>

      <div class="conteudo-principal-cadastroDeUsuarios">
        <h1>Cadastro de Novos Usuários</h1>
        <div class="formulario-cadastro-usuarios">
          <% if (alerta) { %>
            <div id="modalAlerta" class="modal-backdrop show">
              <div class="modal-card">
                <p><%= alerta %></p>
                <button type="button" id="modalClose">OK</button>
              </div>
            </div>
          <% } %>

          <form action="/cadastroDeUsuarios" method="POST" autocomplete="off">
            <div class="nomeUsuario-fomulario-cadastroUsuarios">
              <label for="nome-usuario">Nome Completo:</label>
              <input
                type="text"
                id="nome-usuario"
                name="nome_usuario"
                autocomplete="off"
                value="<%= (dados && dados.nome_usuario) || '' %>"
                required
                title="Insira o nome completo do usuário."
              />
            </div>

            <div class="CPFusuario-fomulario-cadastroUsuarios">
              <label for="cpf-usuario"> Número de CPF :</label>
              <input
                type="number"
                id="cpf-usuario"
                name="cpf_usuario"
                autocomplete="off"
                value="<%= (dados && dados.cpf_usuario) || '' %>"
                required
                title="Insira o CPF do usuário."
                max="99999999999"
                inputmode="numeric"
                oninput="this.value = this.value.replace(/\D/g, '');"
                class="input-number"
              />
            </div>

            <button class="botao-registrar-cadastroUsuarios" type="submit">
              Cadastrar Usuário
            </button>
          </form>
        </div>
      </div>
    </div>

    <%- include('partials/footer') %>
    <script src="/js/cadastroRegistro_modal.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        var form = document.querySelector('form');
        if (!form) return;

        var navigationEntries = performance.getEntriesByType('navigation');
        var isReload = navigationEntries.length > 0 && navigationEntries[0].type === 'reload';

        if (isReload) {
          form.reset();
        }
      });

      window.addEventListener('pageshow', function (event) {
        if (event.persisted) {
          var form = document.querySelector('form');
          if (form) form.reset();
        }
      });
    </script>
  </body>
</html>
