<!DOCTYPE html>
<html lang="pt-br">
<%- include('partials/head') %>

    <body>
        <%- include('partials/header') %>

            <div class="divisao-tela">
                <!-- NÃO APAGUEM ESSA DIV!!! É ela que mantem o layout das views. Coloquem o conteúdo dentro dela a partir do include do nav-->
                <%- include('partials/nav') %>

                    <main class="conteudo-principal-listagemUsuarios">
                        <h1>Lista de Usuários</h1>
                        <table>
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Nome Completo</th>
                                    <th>CPF</th>
                                </tr>
                            </thead>
                            <tbody id="tabela-ListagemUsuarios">
                                <% dados.forEach((usuario, indice) => { %>
                                    <tr>
                                        <td>
                                            <%= indice %>
                                        </td>
                                        <td>
                                            <%= usuario.nome_usuario %>
                                        </td>
                                        <td>
                                            <%= usuario.cpf_usuario %>
                                        </td>
                                    </tr>
                                    <%  }); %>
                            </tbody>
                        </table>
                    </main>
            </div>

            <%- include('partials/footer') %>
    </body>

</html>